# Keep the build context tiny — avoid copying caches, VCS, tests, docs.

.git/
.github/
.githooks/
.opencode/
.pcpm/
.serena/
.vscode/
.idea/

# Caches
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage_html/
coverage.xml
htmlcov/
node_modules/

# Virtual envs
.venv/
venv/
env/
ENV/

# Tests + fixtures are not needed at runtime
tests/

# Docs + meta
*.md
!README.md
LICENSE
CHANGELOG.md
CONTRIBUTING.md
SECURITY.md
AGENTS.md
A2A-CARD.md
llms.txt
governance/
config/

# Secrets / local state
.env
.env.*
.secrets.baseline
*.pem
*.key

# Local runtime artifacts
heypiggy_run_*/
screenshots/
audit/
sessions/
run_summary.json
fail_report_*.md
fail_analysis_*.json
*.log

# CI-only
Makefile
requirements-dev.txt
.pre-commit-config.yaml
.editorconfig
.dockerignore
Dockerfile
