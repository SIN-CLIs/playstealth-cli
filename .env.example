# =============================================================================
# HeyPiggy Vision Worker — sample environment configuration
# =============================================================================
# Copy to `.env` (never commit) and fill in real values.
#
#   cp .env.example .env
# -----------------------------------------------------------------------------

# --- Required: NVIDIA NIM vision API ----------------------------------------
# Primary vision backend. Obtain from https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# --- Required: HeyPiggy platform credentials --------------------------------
HEYPIGGY_EMAIL=
HEYPIGGY_PASSWORD=

# --- Optional: vision backend selection -------------------------------------
# auto     = NVIDIA with opencode CLI fallback (default)
# nvidia   = force NVIDIA only
# opencode = force opencode CLI only
VISION_BACKEND=auto
VISION_MODEL=google/antigravity-gemini-3-flash

# --- Optional: NVIDIA advanced --------------------------------------------
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_PRIMARY_MODEL=nvidia/meta/llama-3.2-11b-vision-instruct
# Comma-separated fallback chain
NVIDIA_FALLBACK_MODELS=nvidia/microsoft/phi-3.5-vision-instruct,nvidia/microsoft/phi-3-vision-128k-instruct
NVIDIA_TIMEOUT=120
NVIDIA_MAX_INLINE_BYTES=150000

# --- Optional: bridge endpoints --------------------------------------------
BRIDGE_MCP_URL=https://openjerro-opensin-bridge-mcp.hf.space/mcp
BRIDGE_HEALTH_URL=https://openjerro-opensin-bridge-mcp.hf.space/health
BRIDGE_CONNECT_TIMEOUT=600

# --- Optional: vision-gate loop limits --------------------------------------
MAX_STEPS=120
MAX_RETRIES=5
MAX_NO_PROGRESS=15
MAX_CLICK_ESCALATIONS=5
VISION_CLI_TIMEOUT=180

# --- Optional: fail-replay recorder ----------------------------------------
RECORDER_FPS=1.0
RECORDER_BUFFER_SECONDS=120
RECORDER_KEYFRAMES=12

# --- Optional: artifact directories ----------------------------------------
# Per-run folder will be HEYPIGGY_ARTIFACT_BASE/heypiggy_run_<RUN_ID>/
HEYPIGGY_ARTIFACT_BASE=/tmp
# Leave empty to auto-generate timestamp-based run id.
HEYPIGGY_RUN_ID=

# --- Optional: profile override --------------------------------------------
# Overrides the default profile lookup. Absolute path preferred.
# HEYPIGGY_PROFILE_PATH=/absolute/path/to/profile.json

# --- Optional: logging ------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR | CRITICAL
HEYPIGGY_LOG_LEVEL=INFO
# json (prod) | console (dev)
HEYPIGGY_LOG_FORMAT=json

# --- Optional: OpenTelemetry ------------------------------------------------
# Install with `pip install -e '.[otel]'` to enable.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=heypiggy-vision-worker
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Optional: fail-report publication -------------------------------------
# Box storage upload for keyframe PNGs. Leave empty to skip.
BOX_STORAGE_URL=
BOX_STORAGE_API_KEY=
